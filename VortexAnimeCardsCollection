-- ========== RARITY SETTINGS ==========
local RARITIES = {
    Common = { sellValue = 25, levelCost = 50, powerMultiplier = 1.0 },
    Rare = { sellValue = 75, levelCost = 120, powerMultiplier = 1.2 },
    Epic = { sellValue = 200, levelCost = 300, powerMultiplier = 1.5 },
