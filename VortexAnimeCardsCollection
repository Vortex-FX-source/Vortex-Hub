}

-- ========== PLAYER DATA ==========
local playerData = {
    currency = 500,
    collection = {},
    stats = { packsOpened = 0, cardsSold = 0, uniqueCards = 0, highestPower = 0 },
    daily = { lastClaim = nil, streak = 0 }
}

-- ========== SAVE/LOAD (with fallback) ==========
local function saveData()
    local success, err = pcall(function()
        if writefile then
            writefile(SAVE_FILE, game:GetService("HttpService"):JSONEncode(playerData))
        else
            -- store in global (will be lost on reset, but better than nothing)
            _G.VortexSave = playerData
        end
    end)
    if not success then debugMsg("Save failed: " .. tostring(err)) end
end

local function loadData()
    local success, data = pcall(function()
        if isfile and isfile(SAVE_FILE) then
            return readfile(SAVE_FILE)
        elseif _G.VortexSave then
            return game:GetService("HttpService"):JSONEncode(_G.VortexSave)
        end
        return nil
    end)
    if success and data then
        local decoded = game:GetService("HttpService"):JSONDecode(data)
        playerData.currency = decoded.currency or 500
        playerData.collection = decoded.collection or {}
        playerData.stats = decoded.stats or playerData.stats
        playerData.daily = decoded.daily or { lastClaim = nil, streak = 0 }
    end
    -- ensure cardInfo for each owned card
    for name, data in pairs(playerData.collection) do
        if not data.cardInfo then
            for _, card in ipairs(cardDatabase) do
                if card.name == name then
                    data.cardInfo = card
                    break
                end
            end
        end
    end
    updateStats()
end

local function updateStats()
    local unique = 0
    for _, v in pairs(playerData.collection) do
        if v.count > 0 then unique = unique + 1 end
    end
    playerData.stats.uniqueCards = unique
end

-- ========== CARD MECHANICS ==========
local function getRandomCard()
    local weights = { Common = 60, Rare = 25, Epic = 10, Legendary = 4, Mythic = 1 }
    local total = 100
    local rand = math.random(1, total)
    local cumulative = 0
    local chosenRarity = "Common"
    for r, w in pairs(weights) do
        cumulative = cumulative + w
        if rand <= cumulative then chosenRarity = r break end
    end
    local possible = {}
    for _, card in ipairs(cardDatabase) do
        if card.rarity == chosenRarity then table.insert(possible, card) end
    end
    if #possible == 0 then return cardDatabase[1] end
    return possible[math.random(1, #possible)]
end

local function openPack(packName, cost, cardCount)
    if playerData.currency < cost then
        Rayfield:Notify({Title = "Not enough coins", Content = string.format("Need %d coins", cost), Duration = 2})
        return false
    end
    playerData.currency = playerData.currency - cost
    playerData.stats.packsOpened = playerData.stats.packsOpened + 1
    local newCards = {}
    for i = 1, cardCount do
        local card = getRandomCard()
        if not playerData.collection[card.name] then
            playerData.collection[card.name] = { count = 0, level = 1, power = card.basePower, cardInfo = card }
        end
        playerData.collection[card.name].count = playerData.collection[card.name].count + 1
        playerData.collection[card.name].power = math.max(playerData.collection[card.name].power, card.basePower)
        table.insert(newCards, card.name .. " [" .. card.rarity .. "]")
    end
    updateStats()
    saveData()
    Rayfield:Notify({Title = packName .. " Opened!", Content = "You got:\n" .. table.concat(newCards, "\n"), Duration = 5})
    refreshCurrency()
    refreshCollection()
    return true
end

local function levelUpCard(cardName)
    local card = playerData.collection[cardName]
    if not card or card.count <= 1 then
        Rayfield:Notify({Title = "Cannot level", Content = "Need at least 1 duplicate", Duration = 2})
        return
    end
    local cost = RARITIES[card.cardInfo.rarity].levelCost
    if playerData.currency < cost then
        Rayfield:Notify({Title = "Not enough coins", Content = string.format("Level up costs %d coins", cost), Duration = 2})
        return
    end
    playerData.currency = playerData.currency - cost
    card.count = card.count - 1
    card.level = card.level + 1
    local powerGain = math.floor(card.cardInfo.basePower * (RARITIES[card.cardInfo.rarity].powerMultiplier - 1) * (card.level / 10))
    card.power = card.power + powerGain
    if card.power > playerData.stats.highestPower then playerData.stats.highestPower = card.power end
    saveData()
    Rayfield:Notify({Title = "Level Up!", Content = string.format("%s now level %d (+%d power)", cardName, card.level, powerGain), Duration = 3})
    refreshCurrency()
    refreshCollection()
end

local function sellCard(cardName, sellAll)
    local card = playerData.collection[cardName]
    if not card or card.count == 0 then return end
    local sellValue = RARITIES[card.cardInfo.rarity].sellValue
    local amount = 0
    if sellAll and card.count > 1 then
        amount = (card.count - 1) * sellValue
        card.count = 1
    elseif not sellAll and card.count >= 1 then
        amount = sellValue
        card.count = card.count - 1
        if card.count == 0 then playerData.collection[cardName] = nil end
    else
        Rayfield:Notify({Title = "Nothing to sell", Content = "You need duplicates to sell all.", Duration = 2})
        return
    end
    playerData.currency = playerData.currency + amount
    playerData.stats.cardsSold = playerData.stats.cardsSold + (sellAll and (card and (card.count == 1 and 1 or 0)) or 1)
    updateStats()
    saveData()
    Rayfield:Notify({Title = "Sold!", Content = string.format("Earned %d coins", amount), Duration = 2})
    refreshCurrency()
    refreshCollection()
end

local function claimDaily()
    local today = os.date("%Y%m%d")
    if playerData.daily.lastClaim == today then
        Rayfield:Notify({Title = "Already claimed", Content = "Come back tomorrow", Duration = 2})
        return
    end
    local yesterday = os.date("%Y%m%d", os.time() - 86400)
    if playerData.daily.lastClaim == yesterday then
        playerData.daily.streak = playerData.daily.streak + 1
    else
        playerData.daily.streak = 1
    end
    local bonus = math.min(200 + playerData.daily.streak * 25, 600)
    playerData.currency = playerData.currency + bonus
    playerData.daily.lastClaim = today
    saveData()
    Rayfield:Notify({Title = "Daily Bonus!", Content = string.format("Streak: %d | +%d coins", playerData.daily.streak, bonus), Duration = 3})
    refreshCurrency()
end

