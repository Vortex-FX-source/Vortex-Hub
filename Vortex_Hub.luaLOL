function KillAura()
    task.spawn(function()
        while true do
            if not getgenv().AutoKillAura then task.wait(); continue end
            local char = Player.Character
            if not char or not char.PrimaryPart then task.wait(); continue end
            local nearest, bestDist = nil, math.huge
            for _,target in pairs(Players:GetPlayers()) do
                if target ~= Player and target.Character and target.Character:FindFirstChild("HumanoidRootPart") and target.Character:FindFirstChild("Humanoid") and target.Character.Humanoid.Health > 0 then
                    local d = (char.PrimaryPart.Position - target.Character.HumanoidRootPart.Position).Magnitude
                    if d < bestDist then bestDist = d; nearest = target end
                end
            end
            if nearest then
                PlayerTP(nearest.Character.HumanoidRootPart.CFrame * CFrame.new(0,5,0))
                EquipTool()
                ActiveHaki()
                for _ = 1, 10 do
                    PlayerClick()
                    task.wait(0.01)
                end
            end
            task.wait()
        end
    end)
end

function AutoFarmSea()
    task.spawn(function()
        while true do
            if not getgenv().AutoFarmSea then task.wait(); continue end
            local char = Player.Character
            if not char or not char.PrimaryPart then task.wait(); continue end
            local onBoat = false
            for _,v in pairs(char:GetDescendants()) do if v:IsA("VehicleSeat") then onBoat = true; break end end
            if not onBoat then
                FireRemote("ShipwrightTalk", "Buy", "Boat")
                task.wait(2)
            end
            local seaCentre = Sea3 and Vector3.new(-15000,0,500) or Sea2 and Vector3.new(-3000,0,-8000) or Vector3.new(1500,0,2000)
            PlayerTP(CFrame.new(seaCentre))
            local seaEnemies = {"SeaBeast","Terrorshark","Piranha","FishCrewMember","Shark"}
            for _,name in pairs(seaEnemies) do
                local enemy = Enemies:FindFirstChild(name)
                if enemy and enemy:FindFirstChild("HumanoidRootPart") then
                    PlayerTP(enemy.HumanoidRootPart.CFrame * CFrame.new(0,0,30))
                    EquipTool()
                    ActiveHaki()
                    PlayerClick()
                end
            end
            task.wait()
        end
    end)
end

function AutoFarmRaid()
    task.spawn(function()
        while true do
            if not getgenv().AutoFarmRaid then task.wait(); continue end
            if not VerifyTool("Special Microchip") and getgenv().AutoBuyChip then
                FireRemote("RaidsNpc", "Select", getgenv().SelectRaidChip)
                task.wait(1)
            end
            if not Player.PlayerGui.Main.Timer.Visible then
                local summon = nil
                if Sea2 and workspace.Map and workspace.Map.CircleIsland then
                    summon = workspace.Map.CircleIsland.RaidSummon2.Button.Main.ClickDetector
                elseif workspace.Map and workspace.Map["Boat Castle"] then
                    summon = workspace.Map["Boat Castle"].RaidSummon2.Button.Main.ClickDetector
                end
                if summon then fireclickdetector(summon) end
                repeat task.wait() until Player.PlayerGui.Main.Timer.Visible
                task.wait(1)
            end
            while Player.PlayerGui.Main.Timer.Visible and getgenv().AutoFarmRaid do
                EquipTool()
                local islands = workspace._WorldOrigin and workspace._WorldOrigin.Locations
                if islands then
                    for i = 5,1,-1 do
                        local island = islands:FindFirstChild("Island "..i)
                        if island then
                            PlayerTP(island.CFrame + Vector3.new(0,70,0))
                            for _,enemy in pairs(Enemies:GetChildren()) do
                                if enemy:FindFirstChild("HumanoidRootPart") and (island.Position - enemy.HumanoidRootPart.Position).Magnitude < 300 then
                                    PlayerClick()
                                    task.wait(0.05)
                                end
                            end
                        end
                    end
                end
                task.wait()
            end
            task.wait(1)
        end
    end)
end

function AutoFarmMaterial()
    task.spawn(function()
        while true do
            if not getgenv().AutoFarmMaterial then task.wait(2); continue end
            local materialList = {}
