-- ============================================
-- FARMING LOOPS (All fully implemented)
-- ============================================
function AutoFarm_Level()
    task.spawn(function()
        while true do
            if not getgenv().AutoFarm_Level then task.wait(); continue end
            local char = Player.Character
            if not char or not char.PrimaryPart then task.wait(); continue end
            local nearest, bestDist = nil, math.huge
            for _,enemy in pairs(Enemies:GetChildren()) do
                if enemy:FindFirstChild("HumanoidRootPart") and enemy:FindFirstChild("Humanoid") and enemy.Humanoid.Health > 0 then
                    local d = (char.PrimaryPart.Position - enemy.HumanoidRootPart.Position).Magnitude
                    if d < bestDist then bestDist = d; nearest = enemy end
                end
            end
            if nearest then
                PlayerTP(nearest.HumanoidRootPart.CFrame * CFrame.new(0,5,0))
                EquipTool()
                ActiveHaki()
                while nearest and nearest:FindFirstChild("Humanoid") and nearest.Humanoid.Health > 0 and getgenv().AutoFarm_Level do
                    PlayerClick()
                    task.wait(0.05)
                end
            end
            task.wait()
        end
    end)
end

