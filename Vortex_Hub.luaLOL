-- ============================================
-- FRUIT COLLECTOR & SNIPER
-- ============================================
function FruitSniper()
    task.spawn(function()
        while true do
            if not getgenv().FruitSniper then task.wait(2); continue end
            local char = Player.Character
            if not char or not char.PrimaryPart then task.wait(1); continue end
            local fruits = {}
            for _,v in pairs(workspace:GetDescendants()) do
                if v:IsA("Tool") and v:FindFirstChild("Handle") and (v.Name:match("Fruit") or v:FindFirstChild("Fruit")) then
                    table.insert(fruits, v)
                end
            end
            local nearest, bestDist = nil, math.huge
            for _,fruit in pairs(fruits) do
                local handle = fruit:FindFirstChild("Handle")
                if handle then
                    local d = (char.PrimaryPart.Position - handle.Position).Magnitude
                    if d < bestDist then bestDist = d; nearest = fruit end
                end
            end
            if nearest then
                local handle = nearest.Handle
                if handle then
                    PlayerTP(handle.CFrame)
                    task.wait(0.3)
                    fireclickdetector(nearest:FindFirstChild("ClickDetector"))
                end
            end
            task.wait(2)
        end
    end)
end

function AutoStoreFruits()
    task.spawn(function()
        while true do
            if not getgenv().AutoStoreFruits then task.wait(3); continue end
            local remote = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("CommF_")
            if not remote then task.wait(); continue end
            local char = Player.Character
            if char then
                for _,fruit in pairs(char:GetChildren()) do
                    if fruit:IsA("Tool") and fruit:FindFirstChild("Fruit") then
                        pcall(function() remote:InvokeServer("StoreFruit", fruit.Name, fruit) end)
                    end
                end
            end
            for _,fruit in pairs(Player.Backpack:GetChildren()) do
                if fruit:IsA("Tool") and fruit:FindFirstChild("Fruit") then
                    pcall(function() remote:InvokeServer("StoreFruit", fruit.Name, fruit) end)
                end
            end
            task.wait(3)
        end
    end)
end

