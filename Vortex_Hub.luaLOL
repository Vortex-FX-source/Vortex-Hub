-- Remove death effects and suppress errors
task.spawn(function()
    local effectContainer = ReplicatedStorage:WaitForChild("Effect", 9e9):WaitForChild("Container", 9e9)
    RunService.RenderStepped:Connect(function()
        local death = effectContainer:FindFirstChild("Death")
        if death then death:Destroy() end
    end)
    hookfunction(error, function() end)
    hookfunction(warn, function() end)
end)

