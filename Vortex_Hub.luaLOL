end

function AutoChestTween()
    task.spawn(function()
        while true do
            if not getgenv().AutoChestTween then task.wait(1); continue end
            local char = Player.Character
            if not char or not char.PrimaryPart then task.wait(1); continue end
            local nearest, bestDist = nil, math.huge
            for _,obj in pairs(workspace:GetDescendants()) do
                if obj:IsA("BasePart") and (obj.Name == "Chest" or obj.Name == "Chest1" or obj.Name == "Chest2" or obj.Name == "Chest3") then
                    local d = (char.PrimaryPart.Position - obj.Position).Magnitude
                    if d < bestDist then bestDist = d; nearest = obj end
                end
            end
            if nearest then
                PlayerTP(nearest.CFrame)
                task.wait(0.3)
                local cd = nearest:FindFirstChild("ClickDetector")
                if cd then cd:Fire() end
            end
            task.wait(1)
        end
    end)
end

