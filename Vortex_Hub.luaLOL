-- Visual Admin (ESP + Fullbright)
task.spawn(function()
    while true do
        if getgenv().VisualAdmin then
            Lighting.Brightness = 2
            Lighting.ClockTime = 14
            Lighting.FogEnd = 100000
            Lighting.GlobalShadows = false
            -- Player ESP
            for _,plr in pairs(Players:GetPlayers()) do
                if plr ~= Player and plr.Character and plr.Character:FindFirstChild("Head") then
                    local head = plr.Character.Head
                    if not head:FindFirstChild("VortexESP") then
                        local bill = Instance.new("BillboardGui", head)
                        bill.Name = "VortexESP"
                        bill.AlwaysOnTop = true
                        bill.Size = UDim2.new(0,8,0,8)
                        bill.StudsOffset = Vector3.new(0,2,0)
                        local text = Instance.new("TextLabel", bill)
                        text.Text = plr.Name .. " [" .. math.floor(plr.Character.Humanoid.Health) .. " HP]"
                        text.TextColor3 = Color3.new(1,0.2,0.2)
                        text.TextScaled = true
                        text.Size = UDim2.new(1,0,1,0)
                        text.BackgroundTransparency = 1
                        text.Font = Enum.Font.GothamBold
                    end
                end
            end
            -- Chest ESP
            for _,chest in pairs(workspace:GetDescendants()) do
                if chest:IsA("BasePart") and (chest.Name == "Chest" or chest.Name == "Chest1" or chest.Name == "Chest2" or chest.Name == "Chest3") then
                    if not chest:FindFirstChild("ChestESP") then
                        local bill = Instance.new("BillboardGui", chest)
                        bill.Name = "ChestESP"
                        bill.AlwaysOnTop = true
                        bill.Size = UDim2.new(0,5,0,5)
                        local text = Instance.new("TextLabel", bill)
                        text.Text = "💰 CHEST"
                        text.TextColor3 = Color3.new(1,1,0)
                        text.TextScaled = true
                        text.Size = UDim2.new(1,0,1,0)
                        text.BackgroundTransparency = 1
                    end
                end
            end
            -- Fruit ESP
            for _,fruit in pairs(workspace:GetDescendants()) do
                if fruit:IsA("Tool") and fruit:FindFirstChild("Handle") and (fruit.Name:match("Fruit") or fruit:FindFirstChild("Fruit")) then
                    local handle = fruit.Handle
                    if handle and not handle:FindFirstChild("FruitESP") then
                        local bill = Instance.new("BillboardGui", handle)
                        bill.Name = "FruitESP"
                        bill.AlwaysOnTop = true
                        bill.Size = UDim2.new(0,6,0,6)
                        local text = Instance.new("TextLabel", bill)
                        text.Text = "🍎 " .. fruit.Name
                        text.TextColor3 = Color3.new(0.5,1,0.5)
                        text.TextScaled = true
                        text.Size = UDim2.new(1,0,1,0)
                        text.BackgroundTransparency = 1
                    end
                end
            end
        else
            Lighting.Brightness = 1
            Lighting.FogEnd = 1000
            Lighting.GlobalShadows = true
            for _,plr in pairs(Players:GetPlayers()) do
                if plr.Character and plr.Character:FindFirstChild("Head") then
                    local esp = plr.Character.Head:FindFirstChild("VortexESP")
                    if esp then esp:Destroy() end
                end
            end
            for _,chest in pairs(workspace:GetDescendants()) do
                if chest:IsA("BasePart") then
                    local esp = chest:FindFirstChild("ChestESP")
                    if esp then esp:Destroy() end
                end
            end
            for _,fruit in pairs(workspace:GetDescendants()) do
                if fruit:IsA("Tool") and fruit:FindFirstChild("Handle") then
                    local esp = fruit.Handle:FindFirstChild("FruitESP")
                    if esp then esp:Destroy() end
                end
            end
        end
        task.wait(1)
    end
end)

