            elseif Sea3 then
                materialList = {"Leather", "Scrap Metal", "Fish Tail", "Gunpowder", "Mini Tusk", "Conjured Cocoa", "Dragon Scale"}
            end
            for _, mat in pairs(materialList) do
                local item = workspace:FindFirstChild(mat)
                if item and item:FindFirstChild("ClickDetector") then
                    PlayerTP(item.CFrame)
                    task.wait(0.3)
                    fireclickdetector(item)
                end
            end
            task.wait(2)
        end
    end)
end

