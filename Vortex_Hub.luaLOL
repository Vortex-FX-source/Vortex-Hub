function OniAura()
    task.spawn(function()
        while true do
            if not getgenv().OniAura then task.wait(0.5); continue end
            local char = Player.Character
            if char then
                for _,v in pairs(char:GetDescendants()) do
                    if v:IsA("ParticleEmitter") then v.Enabled = true end
                end
            end
            task.wait(0.5)
        end
    end)
end

function AutoGift()
    task.spawn(function()
        while true do
            if not getgenv().AutoGift then task.wait(); continue end
            local function GetGift()
                for _,part in pairs(workspace:GetDescendants()) do
                    if part.Name == "Present" and part:FindFirstChild("Box") and part.Box:FindFirstChild("ProximityPrompt") then
                        return part, part.Box.ProximityPrompt
                    end
                end
            end
            local Gift, Prompt = GetGift()
            if Gift and Gift.PrimaryPart then
                PlayerTP(Gift.PrimaryPart.CFrame)
                if Prompt then
                    Prompt:InputHoldBegin()
                    task.wait(0.5)
                    Prompt:InputHoldEnd()
                end
            else
                if Sea3 then PlayerTP(CFrame.new(-1076, 14, -14437))
                elseif Sea2 then PlayerTP(CFrame.new(-5219, 15, 1532))
                elseif Sea1 then PlayerTP(CFrame.new(1007, 15, -3805)) end
            end
            task.wait(1)
        end
    end)
end

function AutoCandy()
    task.spawn(function()
        while true do
            if not getgenv().AutoCandy then task.wait(); continue end
            local char = Player.Character
            if not char or not char.PrimaryPart then task.wait(); continue end
            local function GetCandyNPC()
                for _,npc in pairs(Enemies:GetChildren()) do
                    if npc.Name == "Isle Champion" or npc.Name == "Sun-kissed Warrior" or npc.Name == "Island Boy" or npc.Name == "Isle Outlaw" then
                        if npc:FindFirstChild("HumanoidRootPart") and npc:FindFirstChild("Humanoid") and npc.Humanoid.Health > 0 then
                            return npc
                        end
                    end
                end
                return nil
            end
            local enemy = GetCandyNPC()
            if enemy then
                PlayerTP(enemy.HumanoidRootPart.CFrame + getgenv().FarmPos)
                EquipTool()
                ActiveHaki()
                PlayerClick()
                BringNPC(enemy)
            end
            task.wait()
        end
    end)
end

