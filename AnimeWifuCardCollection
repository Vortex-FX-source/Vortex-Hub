--################================ 1. MAIN TAB ================################--
local MainTab = Window:CreateTab("Main Farm", 4483362458)
MainTab:CreateSection("Auto Farming")

MainTab:CreateToggle({
   Name = "Auto Collect Cash",
   CurrentValue = false,
   Flag = "AutoCollectFlag",
   Callback = function(Value)
      SaveFile.AutoCollect = Value
      if SaveFile.AutoCollect then
         task.spawn(function()
            while SaveFile.AutoCollect do
               CollectAllCardCash:FireServer()
               task.wait(1) 
            end
         end)
      end
   end,
})

MainTab:CreateButton({Name = "Collect All Cash (Once)", Callback = function() CollectAllCardCash:FireServer() end})

MainTab:CreateButton({
   Name = "Collect All Grade Tokens",
   Callback = function()
      local character = Player.Character or Player.CharacterAdded:Wait()
      local hrp = character:WaitForChild("HumanoidRootPart")
      local originalCFrame = hrp.CFrame
      local tokensFolder = Workspace:FindFirstChild("Systems") and Workspace.Systems:FindFirstChild("GradeTokens")
      if not tokensFolder then Rayfield:Notify({Title="Vortex FX", Content="No GradeTokens found!", Duration=3}) return end
      for _, token in ipairs(tokensFolder:GetDescendants()) do
         if token:IsA("BasePart") and token.Name == "GradeToken" then
            hrp.CFrame = token.CFrame + Vector3.new(0, 3, 0)
            task.wait(0.15) 
         end
      end
      task.wait(0.2)
      hrp.CFrame = originalCFrame
   end,
})

--################================ 2. AUTO BUY TAB ================################--
SaveFile.SelectedRarities = {["All"]=false, ["Normal"]=false, ["Gold"]=false, ["Platinum"]=false, ["Emerald"]=false, ["Diamond"]=false, ["Rainbow"]=false}
SaveFile.SelectedRanks = {["Princess"]=false, ["Queen"]=false, ["Matriarch"]=false, ["Empress"]=false, ["Seraph"]=false, ["Divine"]=false, ["Celestial"]=false, ["Goddess"]=false, ["Valkyrie"]=false, ["Archon"]=false}
local AutoBuy = Window:CreateTab("Auto Buy", 4483362458)

AutoBuy:CreateDropdown({
   Name = "Select Active Packs",
   Options = {"Princess", "Queen", "Matriarch", "Empress", "Seraph", "Divine", "Celestial", "Goddess", "Valkyrie", "Archon"},
   CurrentOption = {}, MultipleOptions = true, Flag = "RankDropdown", 
   Callback = function(Options)
      for rank, _ in pairs(SaveFile.SelectedRanks) do SaveFile.SelectedRanks[rank] = false end
      for _, selectedName in ipairs(Options) do SaveFile.SelectedRanks[selectedName] = true end
   end,
})

AutoBuy:CreateDropdown({
    Name = "Select Rarities",
    Options = {"All", "Normal", "Gold", "Platinum", "Emerald", "Diamond", "Rainbow"},
    CurrentOption = {}, MultipleOptions = true, Flag = "RarityDropdown",
    Callback = function(Options)
        for rarity, _ in pairs(SaveFile.SelectedRarities) do SaveFile.SelectedRarities[rarity] = false end
        for _, selected in ipairs(Options) do SaveFile.SelectedRarities[selected] = true end
    end,
})

AutoBuy:CreateToggle({
   Name = "Auto Roll Packs",
   CurrentValue = false, Flag = "AutoRollFlag",
   Callback = function(Value)
      SaveFile.AutoRoll = Value
      if SaveFile.AutoRoll then
         task.spawn(function() while SaveFile.AutoRoll do PackReroll:FireServer(); task.wait(3) end end)
      end
   end,
})

AutoBuy:CreateToggle({
   Name = "Auto Buy Selected Packs",
   CurrentValue = false, Flag = "AutoBuyFlag",
   Callback = function(Value)
      SaveFile.AutoBuyPacks = Value
      if SaveFile.AutoBuyPacks then
         task.spawn(function()
            while SaveFile.AutoBuyPacks do
               local myPlot = Workspace.Map.PlotModels:FindFirstChild(Player.Name)
               local station = myPlot and myPlot:FindFirstChild("Systems") and myPlot.Systems:FindFirstChild("ActivePackStation") and myPlot.Systems.ActivePackStation:FindFirstChild("Station") and myPlot.Systems.ActivePackStation.Station:FindFirstChild("PackParts")
               if station then
                  for i = 1, 4 do
                     local packFolder = station:FindFirstChild("Pack" .. i)
                     if packFolder then
                        for _, item in ipairs(packFolder:GetChildren()) do
                            if item.Name:find("ActivePack") then
                                local itemRank = item.Name:gsub("ActivePack%-", "")
                                local gui = item:FindFirstChild("PackPriceBillboardGui")
                                local itemRarity = (gui and gui:FindFirstChild("Frame") and gui.Frame:FindFirstChild("VariantLabel") and gui.Frame.VariantLabel.Text) or "Normal"
                                if SaveFile.SelectedRanks[itemRank] and (SaveFile.SelectedRarities["All"] or SaveFile.SelectedRarities[itemRarity]) then
                                    PackPurchase:FireServer(i)
                                    task.wait(0.5)
                                    break
                                end
                            end
                        end
                     end
                  end
               end
               task.wait(1) 
            end
         end)
      end
   end,
})

